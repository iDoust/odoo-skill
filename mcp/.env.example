# Odoo MCP Server — Environment Variables
# Copy this file to .env and fill in your Odoo credentials

# Odoo Instance URL (no trailing slash)
ODOO_URL=http://localhost:8069

# Database name
ODOO_DB=odoo

# Odoo login credentials (use a user with appropriate access rights)
# For development/read-only use: create a dedicated technical user
ODOO_USERNAME=admin
ODOO_PASSWORD=admin

# (Optional) Local Source Code Search Paths
# Set these paths if you want the AI agent to be able to search the actual Odoo source code.
# E.g. \\wsl.localhost\Ubuntu-24.04\home\ilham\odoo18
ODOO_17_SOURCE_PATH=
ODOO_18_SOURCE_PATH=
ODOO_19_SOURCE_PATH=
